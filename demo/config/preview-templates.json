{
  "component": {
    "type": "wrap",
    "style": "width: fit-content; max-width: 100%",
    "child": { "type": "demo-component", "passState": true }
  },
  "icon-text": {
    "type": "wrap",
    "style": "width: fit-content; max-width: 100%",
    "child": {
      "type": "demo-component",
      "passState": true,
      "iconFromDetails": "icon",
      "textFromDetails": "text",
      "childrenFromDetails": "text"
    }
  },
  "layout-flex": {
    "type": "surround",
    "inlineFromState": "inline",
    "child": {
      "type": "demo-component",
      "name": "FlexLayout",
      "passState": ["direction", "justify", "items", "wrap", "gap", "inline"],
      "gapDefault": "0.5rem",
      "widthFromInline": true,
      "children": {
        "type": "repeat",
        "countFrom": "details.itemCount",
        "default": 4,
        "min": 1,
        "max": 50,
        "child": { "type": "emoji-card", "inline": true, "cardStyle": "padding: 0.45rem 0.65rem" }
      }
    }
  },
  "layout-grid": {
    "type": "surround",
    "inlineFromState": "inline",
    "child": {
      "type": "demo-component",
      "name": "GridLayout",
      "passState": ["cells", "direction", "gap", "inline"],
      "gapDefault": "0.5rem",
      "widthFromInline": true,
      "children": {
        "type": "repeat",
        "countFrom": "details.itemCount",
        "default": 7,
        "min": 3,
        "max": 50,
        "child": { "type": "emoji-card", "inline": true, "cardStyle": "display: flex; align-items: center; justify-content: center; min-height: 2.35rem" }
      }
    }
  },
  "layout-block": {
    "type": "surround",
    "inlineFromState": "inline",
    "child": {
      "type": "demo-component",
      "name": "BlockLayout",
      "passState": ["inline"],
      "className": "block-layout-preview",
      "widthFromInline": true,
      "children": {
        "type": "repeat",
        "countFrom": "details.itemCount",
        "default": 3,
        "min": 1,
        "max": 50,
        "child": { "type": "emoji-card", "labelPrefix": "Bloque ", "cardStyle": "margin-bottom: 0.45rem; padding: 0.5rem" }
      }
    }
  },
  "layout-splitter": {
    "type": "builtin",
    "id": "layout-splitter"
  },
  "layout-divider": {
    "type": "builtin",
    "id": "layout-divider"
  },
  "layout-app": {
    "type": "builtin",
    "id": "layout-app"
  },
  "layout-side-panel": {
    "type": "builtin",
    "id": "layout-side-panel"
  },
  "contapyme-login": {
    "type": "builtin",
    "id": "contapyme-login"
  },
  "card": {
    "type": "builtin",
    "id": "card"
  },
  "text": {
    "type": "wrap",
    "style": "width: 100%; max-width: 36rem",
    "child": {
      "type": "demo-component",
      "name": "Text",
      "passState": ["color", "lines"],
      "childrenFromDetails": "sampleText"
    }
  },
  "headings": {
    "type": "demo-component",
    "name": "Headings",
    "passState": ["color", "lines"],
    "childrenFromDetails": "sampleText"
  },
  "float-button": {
    "type": "wrap",
    "style": "position: relative; min-height: 8rem; display: flex; align-items: flex-end; justify-content: flex-end; padding: 1rem",
    "child": {
      "type": "demo-component",
      "name": "FloatButton",
      "passState": ["type", "shape", "size", "disabled"],
      "iconFromDetails": "icon",
      "textFromDetails": "label",
      "childrenFromDetails": "label"
    }
  },
